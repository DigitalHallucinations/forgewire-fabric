{
  "name": "forgewire-fabric",
  "displayName": "ForgeWire Fabric",
  "description": "Dispatch tasks to a ForgeWire Fabric compute mesh: signed envelopes, scope-bound capability tokens, live stream output. Run a hub or runner from inside VS Code on Windows, macOS, or Linux.",
  "version": "0.1.1",
  "publisher": "DigitalHallucinations",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "forgewire-fabric",
    "distributed",
    "cluster",
    "task-dispatch",
    "ai-agents",
    "remote-execution"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DigitalHallucinations/forgewire-fabric.git",
    "directory": "vscode"
  },
  "homepage": "https://github.com/DigitalHallucinations/forgewire-fabric",
  "bugs": {
    "url": "https://github.com/DigitalHallucinations/forgewire-fabric/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "ForgeWire Fabric",
      "properties": {
        "forgewireFabric.hubUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the ForgeWire hub (e.g. http://hub.local:8765). Leave empty to be prompted on first connect."
        },
        "forgewireFabric.hubToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token for the hub. **Treat as a secret** \u2014 prefer SecretStorage via the *ForgeWire: Set Hub Token* command."
        },
        "forgewireFabric.hubTokenFile": {
          "type": "string",
          "default": "",
          "description": "Path to a file containing the hub bearer token. Used when forgewire.hubToken is empty. Defaults to ~/.forgewire/hub.token when present."
        },
        "forgewireFabric.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python interpreter used to install / launch the forgewire CLI. Empty = auto-detect (uses python.defaultInterpreterPath, then 'python3', then 'python')."
        },
        "forgewireFabric.refreshIntervalSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "description": "How often to refresh the runners and tasks tree views."
        },
        "forgewireFabric.autoStartHubPort": {
          "type": "number",
          "default": 8765,
          "description": "Default port used by 'ForgeWire: Start Hub Here'."
        }
      }
    },
    "commands": [
      {
        "command": "forgewireFabric.installCli",
        "title": "Install / Update CLI (pip install forgewire-fabric)",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.connectHub",
        "title": "Connect to Hub\u2026",
        "category": "ForgeWire Fabric",
        "icon": "$(plug)"
      },
      {
        "command": "forgewireFabric.setToken",
        "title": "Set Hub Token\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.disconnect",
        "title": "Disconnect",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.startHubHere",
        "title": "Start Hub Here\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.startRunnerHere",
        "title": "Start Runner Here\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.dispatchTask",
        "title": "Dispatch Task\u2026",
        "category": "ForgeWire Fabric",
        "icon": "$(rocket)"
      },
      {
        "command": "forgewireFabric.refresh",
        "title": "Refresh",
        "category": "ForgeWire Fabric",
        "icon": "$(refresh)"
      },
      {
        "command": "forgewireFabric.streamTask",
        "title": "Tail Task Stream",
        "category": "ForgeWire Fabric",
        "icon": "$(output)"
      },
      {
        "command": "forgewireFabric.cancelTask",
        "title": "Cancel Task",
        "category": "ForgeWire Fabric",
        "icon": "$(stop-circle)"
      },
      {
        "command": "forgewireFabric.showTask",
        "title": "Show Task",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.copyToken",
        "title": "Copy Hub Token to Clipboard",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.generateToken",
        "title": "Generate New Hub Token",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.openSettings",
        "title": "Open Settings…",
        "category": "ForgeWire Fabric",
        "icon": "$(gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forgewireFabric",
          "title": "ForgeWire Fabric",
          "icon": "media/sidebar.svg"
        }
      ]
    },
    "views": {
    "forgewireFabric": [
        {
          "id": "forgewireFabric.hub",
          "name": "Hub",
          "icon": "$(plug)",
          "contextualTitle": "ForgeWire Fabric Hub"
        },
        {
          "id": "forgewireFabric.runners",
          "name": "Runners",
          "icon": "$(server)",
          "contextualTitle": "ForgeWire Fabric Runners"
        },
        {
          "id": "forgewireFabric.tasks",
          "name": "Tasks",
          "icon": "$(checklist)",
          "contextualTitle": "ForgeWire Fabric Tasks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "forgewireFabric.hub",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)\n\n[Open Settings](command:forgewireFabric.openSettings)\n\n[Start a Hub Locally](command:forgewireFabric.startHubHere)"
      },
      {
        "view": "forgewireFabric.runners",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)\n\n[Start a Hub Locally](command:forgewireFabric.startHubHere)\n\n[Install the CLI](command:forgewireFabric.installCli)\n\nFirst time? Read the [ForgeWire Fabric quickstart](https://github.com/DigitalHallucinations/forgewire-fabric/blob/main/docs/QUICKSTART.md)."
      },
      {
        "view": "forgewireFabric.tasks",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forgewireFabric.refresh",
          "when": "view == forgewireFabric.runners || view == forgewireFabric.tasks || view == forgewireFabric.hub",
          "group": "navigation@1"
        },
        {
          "command": "forgewireFabric.openSettings",
          "when": "view == forgewireFabric.hub",
          "group": "navigation@2"
        },
        {
          "command": "forgewireFabric.dispatchTask",
          "when": "view == forgewireFabric.tasks",
          "group": "navigation@2"
        },
        {
          "command": "forgewireFabric.connectHub",
          "when": "view == forgewireFabric.runners",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "forgewireFabric.streamTask",
          "when": "view == forgewireFabric.tasks && viewItem == task",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.cancelTask",
          "when": "view == forgewireFabric.tasks && viewItem == task",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.showTask",
          "when": "view == forgewireFabric.tasks && viewItem == task"
        }
      ],
      "commandPalette": [
        {
          "command": "forgewireFabric.streamTask"
        },
        {
          "command": "forgewireFabric.cancelTask"
        },
        {
          "command": "forgewireFabric.showTask"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.32.0"
  }
}
