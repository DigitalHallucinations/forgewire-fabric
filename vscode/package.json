{
  "name": "forgewire-fabric",
  "displayName": "ForgeWire Fabric",
  "description": "Dispatch tasks to a ForgeWire Fabric compute mesh: signed envelopes, scope-bound capability tokens, live stream output. Run a hub or runner from inside VS Code on Windows, macOS, or Linux.",
  "version": "0.1.5",
  "publisher": "DigitalHallucinations",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "forgewire-fabric",
    "distributed",
    "cluster",
    "task-dispatch",
    "ai-agents",
    "remote-execution"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DigitalHallucinations/forgewire-fabric.git",
    "directory": "vscode"
  },
  "homepage": "https://github.com/DigitalHallucinations/forgewire-fabric",
  "bugs": {
    "url": "https://github.com/DigitalHallucinations/forgewire-fabric/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "ForgeWire Fabric",
      "properties": {
        "forgewireFabric.hubUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the ForgeWire hub (e.g. http://hub.local:8765). Leave empty to be prompted on first connect. When forgewireFabric.hubCandidates is non-empty this acts as an implicit additional candidate at priority 100."
        },
        "forgewireFabric.hubCandidates": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": { "type": "string", "description": "Candidate hub URL." },
              "label": { "type": "string", "description": "Friendly label for the sidebar." },
              "priority": { "type": "number", "default": 100, "description": "Lower = preferred. Probed in ascending order." }
            }
          },
          "markdownDescription": "Ordered list of hub candidates for failover. The extension probes each candidate in priority order and uses the first reachable one as the active hub. Example:\n```\n[\n  { \"url\": \"http://10.120.81.95:8765\", \"label\": \"OptiPlex (always-on)\", \"priority\": 1 },\n  { \"url\": \"http://10.120.81.50:8765\", \"label\": \"Dell\", \"priority\": 2 }\n]\n```"
        },
        "forgewireFabric.hubPin": {
          "type": "string",
          "default": "",
          "description": "Manual override: when set, the extension dispatches to this URL only and does not probe candidates. Use the *Pin to Hub…* command to set this. Clear with *Unpin Hub*."
        },
        "forgewireFabric.hubName": {
          "type": "string",
          "default": "",
          "description": "Friendly display name for the hub (shown in the sidebar and status bar). Purely cosmetic — no effect on hub identity or auth."
        },
        "forgewireFabric.runnerAliases": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "Map of runner_id -> friendly alias. Used as the runner label in the sidebar."
        },
        "forgewireFabric.hubToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token for the hub. **Treat as a secret** \u2014 prefer SecretStorage via the *ForgeWire: Set Hub Token* command."
        },
        "forgewireFabric.hubTokenFile": {
          "type": "string",
          "default": "",
          "description": "Path to a file containing the hub bearer token. Used when forgewire.hubToken is empty. Defaults to ~/.forgewire/hub.token when present."
        },
        "forgewireFabric.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python interpreter used to install / launch the forgewire CLI. Empty = auto-detect (uses python.defaultInterpreterPath, then 'python3', then 'python')."
        },
        "forgewireFabric.refreshIntervalSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "description": "How often to refresh the runners and tasks tree views."
        },
        "forgewireFabric.autoStartHubPort": {
          "type": "number",
          "default": 8765,
          "description": "Default port used by 'ForgeWire: Start Hub Here'."
        }
      }
    },
    "commands": [
      {
        "command": "forgewireFabric.installCli",
        "title": "Install / Update CLI (pip install forgewire-fabric)",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.connectHub",
        "title": "Connect to Hub\u2026",
        "category": "ForgeWire Fabric",
        "icon": "$(plug)"
      },
      {
        "command": "forgewireFabric.setToken",
        "title": "Set Hub Token\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.disconnect",
        "title": "Disconnect",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.startHubHere",
        "title": "Start Hub Here\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.startRunnerHere",
        "title": "Start Runner Here\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.dispatchTask",
        "title": "Dispatch Task\u2026",
        "category": "ForgeWire Fabric",
        "icon": "$(rocket)"
      },
      {
        "command": "forgewireFabric.refresh",
        "title": "Refresh",
        "category": "ForgeWire Fabric",
        "icon": "$(refresh)"
      },
      {
        "command": "forgewireFabric.streamTask",
        "title": "Tail Task Stream",
        "category": "ForgeWire Fabric",
        "icon": "$(output)"
      },
      {
        "command": "forgewireFabric.cancelTask",
        "title": "Cancel Task",
        "category": "ForgeWire Fabric",
        "icon": "$(stop-circle)"
      },
      {
        "command": "forgewireFabric.showTask",
        "title": "Show Task",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.copyToken",
        "title": "Copy Hub Token to Clipboard",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.generateToken",
        "title": "Generate New Hub Token",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.openSettings",
        "title": "Open Settings…",
        "category": "ForgeWire Fabric",
        "icon": "$(gear)"
      },
      {
        "command": "forgewireFabric.renameHub",
        "title": "Rename Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(edit)"
      },
      {
        "command": "forgewireFabric.renameRunner",
        "title": "Rename Runner…",
        "category": "ForgeWire Fabric",
        "icon": "$(edit)"
      },
      {
        "command": "forgewireFabric.pauseRunner",
        "title": "Pause Runner (drain)",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-pause)"
      },
      {
        "command": "forgewireFabric.resumeRunner",
        "title": "Resume Runner",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-start)"
      },
      {
        "command": "forgewireFabric.restartRunnerService",
        "title": "Restart Runner Service (local)",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-restart)"
      },
      {
        "command": "forgewireFabric.startRunnerService",
        "title": "Start Runner Service (local)",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.stopRunnerService",
        "title": "Stop Runner Service (local)",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-stop)"
      },
      {
        "command": "forgewireFabric.pinHub",
        "title": "Pin to Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(pin)"
      },
      {
        "command": "forgewireFabric.unpinHub",
        "title": "Unpin Hub",
        "category": "ForgeWire Fabric",
        "icon": "$(pinned)"
      },
      {
        "command": "forgewireFabric.promoteHub",
        "title": "Promote This Node to Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(arrow-up)"
      },
      {
        "command": "forgewireFabric.demoteHub",
        "title": "Demote Active Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(arrow-down)"
      },
      {
        "command": "forgewireFabric.editHubCandidates",
        "title": "Edit Hub Candidates…",
        "category": "ForgeWire Fabric",
        "icon": "$(list-tree)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forgewireFabric",
          "title": "ForgeWire Fabric",
          "icon": "media/sidebar.svg"
        }
      ]
    },
    "views": {
    "forgewireFabric": [
        {
          "id": "forgewireFabric.hub",
          "name": "Hub",
          "icon": "$(plug)",
          "contextualTitle": "ForgeWire Fabric Hub"
        },
        {
          "id": "forgewireFabric.runners",
          "name": "Runners",
          "icon": "$(server)",
          "contextualTitle": "ForgeWire Fabric Runners"
        },
        {
          "id": "forgewireFabric.tasks",
          "name": "Tasks",
          "icon": "$(checklist)",
          "contextualTitle": "ForgeWire Fabric Tasks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "forgewireFabric.hub",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)\n\n[Open Settings](command:forgewireFabric.openSettings)\n\n[Start a Hub Locally](command:forgewireFabric.startHubHere)",
        "when": "!forgewireFabric.connected"
      },
      {
        "view": "forgewireFabric.runners",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)\n\n[Start a Hub Locally](command:forgewireFabric.startHubHere)\n\n[Install the CLI](command:forgewireFabric.installCli)\n\nFirst time? Read the [ForgeWire Fabric quickstart](https://github.com/DigitalHallucinations/forgewire-fabric/blob/main/docs/QUICKSTART.md).",
        "when": "!forgewireFabric.connected"
      },
      {
        "view": "forgewireFabric.tasks",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)",
        "when": "!forgewireFabric.connected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forgewireFabric.refresh",
          "when": "view == forgewireFabric.runners || view == forgewireFabric.tasks || view == forgewireFabric.hub",
          "group": "navigation@1"
        },
        {
          "command": "forgewireFabric.openSettings",
          "when": "view == forgewireFabric.hub",
          "group": "navigation@2"
        },
        {
          "command": "forgewireFabric.dispatchTask",
          "when": "view == forgewireFabric.tasks",
          "group": "navigation@2"
        },
        {
          "command": "forgewireFabric.connectHub",
          "when": "view == forgewireFabric.runners",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "forgewireFabric.renameHub",
          "when": "view == forgewireFabric.hub && viewItem == hub.name",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.pinHub",
          "when": "view == forgewireFabric.hub && viewItem == hub.url.auto",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.unpinHub",
          "when": "view == forgewireFabric.hub && viewItem == hub.url.pinned",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.editHubCandidates",
          "when": "view == forgewireFabric.hub && viewItem == hub.candidates",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.renameRunner",
          "when": "view == forgewireFabric.runners && viewItem =~ /^runner\\./",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.pauseRunner",
          "when": "view == forgewireFabric.runners && viewItem =~ /^runner\\.online\\./",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.resumeRunner",
          "when": "view == forgewireFabric.runners && viewItem =~ /^runner\\.draining\\./",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.restartRunnerService",
          "when": "view == forgewireFabric.runners && viewItem =~ /^runner\\.[a-z]+\\.local$/",
          "group": "inline@3"
        },
        {
          "command": "forgewireFabric.stopRunnerService",
          "when": "view == forgewireFabric.runners && viewItem =~ /^runner\\.[a-z]+\\.local$/",
          "group": "runner@2"
        },
        {
          "command": "forgewireFabric.startRunnerService",
          "when": "view == forgewireFabric.runners && viewItem =~ /^runner\\.offline\\.local$/",
          "group": "runner@1"
        },
        {
          "command": "forgewireFabric.streamTask",
          "when": "view == forgewireFabric.tasks && viewItem == task",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.cancelTask",
          "when": "view == forgewireFabric.tasks && viewItem == task",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.showTask",
          "when": "view == forgewireFabric.tasks && viewItem == task"
        }
      ],
      "commandPalette": [
        {
          "command": "forgewireFabric.streamTask"
        },
        {
          "command": "forgewireFabric.cancelTask"
        },
        {
          "command": "forgewireFabric.showTask"
        },
        {
          "command": "forgewireFabric.pauseRunner"
        },
        {
          "command": "forgewireFabric.resumeRunner"
        },
        {
          "command": "forgewireFabric.restartRunnerService"
        },
        {
          "command": "forgewireFabric.startRunnerService"
        },
        {
          "command": "forgewireFabric.stopRunnerService"
        },
        {
          "command": "forgewireFabric.pinHub"
        },
        {
          "command": "forgewireFabric.unpinHub"
        },
        {
          "command": "forgewireFabric.promoteHub"
        },
        {
          "command": "forgewireFabric.demoteHub"
        },
        {
          "command": "forgewireFabric.editHubCandidates"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.32.0"
  }
}
